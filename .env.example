# App
PORT=8000
APP_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins (the alfood front-end)
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=alfood
DB_PASSWORD=alfood
DB_DATABASE=alfood
# Auto-create/update schema from entities. Keep true only in development.
DB_SYNCHRONIZE=true

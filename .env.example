# App
PORT=8000
APP_URL=http://localhost:8000
# Comma-separated list of allowed CORS origins (the alfood front-end)
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=alfood
DB_PASSWORD=alfood
DB_DATABASE=alfood
# Auto-create/update schema from entities. Keep true only in development.
DB_SYNCHRONIZE=true

# Auth (admin)
# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Token lifetime (e.g. 60s, 15m, 1d). See https://github.com/vercel/ms
JWT_EXPIRES_IN=1d
# Single admin user that can access /api/v2.
ADMIN_USERNAME=admin
# bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=
